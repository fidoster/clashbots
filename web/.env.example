# Clashbots frontend env — copy to ".env" for local use, or set in Vercel.
#
# Backend API origin. Leave BLANK for local dev (Vite proxies /api to the local
# backend on :8787). In production set it to your deployed backend URL so the
# static frontend on Vercel can reach the Render backend. No trailing slash.
#
# VITE_API_BASE=https://your-backend.onrender.com
VITE_API_BASE=
