# Clashbots server config — copy to .env and fill in to use real models.
# With NO keys set, everything runs in free "mock" mode.

# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (GPT) — https://platform.openai.com/
OPENAI_API_KEY=

# OpenRouter (DeepSeek, Gemini, Llama, Qwen, Mistral, Grok via one key) — https://openrouter.ai/
OPENROUTER_API_KEY=

# DeepSeek (native API) — https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# NVIDIA NIM (free credits) — https://build.nvidia.com/  (key looks like nvapi-…)
NVIDIA_API_KEY=

# Local LLM server (LM Studio default; Ollama is http://localhost:11434/v1)
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Server
PORT=8787

# ── Public deploy hardening ───────────────────────────────────────────────
# All OFF by default, so local dev is unchanged. Flip these on the host (Render)
# to run a safe public demo. FIRST set a hard monthly spend cap in your provider
# console — that's the real safety net.

# Turn the API into a locked-down public demo (rate limits + config sanitising).
PUBLIC_DEMO=false
# Let visitors bring their own keys / local servers. Usually false on a public
# deploy so nobody can probe arbitrary URLs (SSRF) or hand you their secrets.
ALLOW_BYOK=false
# The single real model the public demo runs on YOUR key (pick a cheap one).
DEMO_MODEL=anthropic:claude-haiku-4-5
# Lock CORS to your deployed frontend origin (no trailing slash).
FRONTEND_ORIGIN=https://your-frontend.vercel.app
# Debate requests allowed per IP per minute (public mode only).
RATE_LIMIT_PER_MIN=20
# Secret required to wipe the leaderboard on a public deploy. Send it as the
# "x-admin-token" header. Leave blank to disable the wipe endpoint entirely in public.
ADMIN_TOKEN=
# SQLite path. On Render, point at a mounted persistent disk so history survives
# restarts/deploys, e.g. /data/clashbots.db
CLASHBOTS_DB=
